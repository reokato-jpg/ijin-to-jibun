rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 会員プロフィール
    // - 他会員はログイン済みなら読み取り可（名前・称号・アバター・trait・SNS・フォロー偉人を公開）
    // - 書き込みは本人のみ
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
