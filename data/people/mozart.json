  "innerConflicts": [
    {
      "title": "父レオポルトの支配と、そこからの独立",
      "period": "1756〜1787",
      "body": "父レオポルトは5歳のモーツァルトを『神童』としてヨーロッパ全土に展示し、一家を養った。成人後も手紙で『食事はどうした』『金を無駄遣いするな』と細かく管理。1781年ザルツブルク大司教との衝突でモーツァルトは『自分の人生を生きる』と父に宣言、ウィーンへ独立。だが父は『お前は破滅する』と怒りの手紙を送り、以後関係が冷え込んだ。1787年レオポルトの死まで、父への反抗と承認欲求の葛藤は続いた。"
    },
    {
      "title": "借金の山、友人に送り続けた『お願い』の手紙",
      "period": "1787〜1791",
      "body": "収入は当時の貴族並みだったが、生活は常に赤字。同志フリーメイソン仲間の商人プフベルクへは16通の借金依頼の手紙が残っている。『親愛なるブラザー、また100グルデン貸してください』。『フィガロの結婚』『魔笛』の大成功にもかかわらず、死の直前まで生活費に苦しんだ。原因は浪費癖と妻コンスタンツェの度重なる療養費。『天才は金銭感覚を持てない』の代表例。"
    },
    {
      "title": "レクイエムの謎の依頼主と、自分の死の予感",
      "period": "1791",
      "body": "1791年7月、黒装束の使者が『誰かの死者のためのレクイエム』を依頼（後にヴァルゼック伯爵と判明）。病気で衰弱していたモーツァルトは『これは私自身のためのレクイエムだ』と確信、書きながら『私は毒殺される』と妻に訴えた。12月5日、未完のまま35歳で死去。弟子ジュスマイアーが補筆して完成。映画『アマデウス』のサリエリ毒殺説はフィクションだが、本人が死を予感していたのは事実。"
    }
  ],
  "turningPoints": [
    {
      "year": 1762,
      "title": "6歳、神童としてヨーロッパ・ツアー開始",
      "body": "6歳でマリア・テレジア女帝の前で演奏、7歳で姉と共にヨーロッパ10年間のツアーへ。パリ、ロンドン、ローマ。14歳でシスティーナ礼拝堂で1度だけ聴いたアレグリ『ミゼレーレ』9声部を完全記譜し音楽史の伝説となった。だがこの英才教育は、彼の大人としての人間関係を歪めた。"
    },
    {
      "year": 1781,
      "title": "ザルツブルク大司教との決別、ウィーンへ独立",
      "body": "25歳、主君コロレド大司教と衝突。『大司教の尻を蹴られて追い出された』と父への手紙に書いた。以後フリーランスの作曲家として、パトロンに縛られず自分の音楽を書く道を選んだ。音楽家が『使用人』から『芸術家』になった象徴的な瞬間。"
    },
    {
      "year": 1791,
      "title": "『魔笛』と『レクイエム』 — 35歳、最後の5ヶ月",
      "body": "最後の数ヶ月でオペラ『魔笛』(9月初演)、『皇帝ティートの慈悲』、クラリネット協奏曲、未完の『レクイエム』——異なる5つの傑作を並行して書いた。『魔笛』初演では体調を崩しながら会場で拍手を受け、帰宅後に倒れた。12月5日未明、『レクイエム』のラクリモサの8小節で筆が止まったまま死去。35歳。"
    }
  ],
  "unknownStories": [
    {
      "title": "スカトロジカルな手紙 — 神童の意外な一面",
      "body": "モーツァルトは従姉妹ベーズレへの手紙で、大量の下ネタ・糞便ジョークを連発した。『私のケツにキスして』系の表現を含む手紙は現在も残存。18世紀ドイツ語圏の文化としては珍しくなかったが、神格化されたモーツァルト像を崩すため、19世紀以降長らく伏せられていた。天才は人間だった、という証拠。"
    },
    {
      "title": "共同墓地に埋葬された — 遺体の場所は今も不明",
      "body": "1791年12月6日、ヴィーンの聖マルクス墓地の共同墓地に埋葬。当時の共同墓地は定期的に掘り返される制度だったため、遺体の正確な場所は今も不明。20世紀に発見された頭蓋骨が彼のものか議論が続いているが、DNA鑑定では確証に至っていない。"
    },
    {
      "title": "フリーメイソンだった — 『魔笛』は秘密儀式の暗号",
      "body": "1784年フリーメイソンに入会、積極的に活動。最後のオペラ『魔笛』には三度打たれる柱、太陽と月、火と水の試練など、メイソン儀式の象徴が散りばめられている。啓蒙主義と神秘主義が同居する彼の世界観の集大成。『葬送のためのフリーメイソン音楽』K.477 はメイソン会員のみに向けて書かれた追悼曲。"
    }
  ]
