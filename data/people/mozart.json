  "birth": 1756,
  "death": 1791,
  "country": "オーストリア",
  "field": "作曲家",
  "summary": "3歳でクラヴィーアを弾き、6歳から欧州を演奏旅行した神童。600曲超を遺し、35歳で謎の死を遂げた。『レクイエム』は未完のまま。",
  "events": [
    {
      "year": 1756,
      "age": 0,
      "title": "ザルツブルクに誕生",
      "detail": "父レオポルトは宮廷音楽家。姉ナンネルも音楽の才を持つ家庭に育つ。",
      "tags": [
        "approval"
      ]
    },
    {
      "year": 1762,
      "age": 6,
      "title": "欧州演奏旅行始まる",
      "detail": "父に連れられ幼くしてヨーロッパ中で演奏。マリア・テレジアの前でも弾いた。",
      "tags": [
        "approval",
        "breakthrough"
      ]
    },
    {
      "year": 1762,
      "age": 6,
      "title": "父レオポルトと欧州演奏旅行開始",
      "detail": "マリア・テレジア、ルイ15世、ジョージ3世の前で演奏。6歳の天才児として欧州中を回る。父は家計と名声のため子供を酷使した。",
      "tags": [
        "approval",
        "parent_conflict"
      ]
    },
    {
      "year": 1770,
      "age": 14,
      "title": "システィーナ礼拝堂のアレグリ『ミゼレーレ』を一度聴いて記憶し再現",
      "detail": "門外不出だった楽譜を14歳の少年が暗譜。法王から黄金の拍車騎士団の叙勲。",
      "tags": [
        "breakthrough",
        "approval"
      ]
    },
    {
      "year": 1777,
      "age": 21,
      "title": "母と二人でパリへ、母を失う",
      "detail": "就職活動のための旅。パリで母が病没、彼は一人で遺体を見送った。",
      "tags": [
        "loss",
        "isolation"
      ]
    },
    {
      "year": 1778,
      "age": 22,
      "title": "パリで母を失う",
      "detail": "就職活動のためのパリ滞在中、同行した母が病死。父への報告書で一足飛びに真実を告げる勇気が持てず、まず『母は重病です』と書いた。",
      "tags": [
        "loss"
      ]
    },
    {
      "year": 1781,
      "age": 25,
      "title": "ザルツブルク大司教と決別、ウィーンへ",
      "detail": "『尻を蹴飛ばされて』放逐された。フリーランス音楽家として生きる決意。当時としては異例の独立。",
      "tags": [
        "restart",
        "pride_broken"
      ]
    },
    {
      "year": 1782,
      "age": 26,
      "title": "コンスタンツェと結婚",
      "detail": "父の反対を押し切って結婚。7人の子を産むも成人したのは2人。",
      "tags": [
        "parent_conflict"
      ]
    },
    {
      "year": 1782,
      "age": 26,
      "title": "コンスタンツェ・ウェーバーと父の反対を押し切り結婚",
      "detail": "ウェーバー家の次女と結婚。父レオポルトは最後まで祝福しなかった。",
      "tags": [
        "parent_conflict",
        "restart"
      ]
    },
    {
      "year": 1783,
      "age": 27,
      "title": "父レオポルトがウィーンを訪問、二人は和解",
      "detail": "数年ぶりの再会。父は『彼らは音楽で私たちを泣かせた』と友人への手紙に書く。",
      "tags": [
        "parent_conflict"
      ]
    },
    {
      "year": 1786,
      "age": 30,
      "title": "『フィガロの結婚』初演",
      "detail": "ダ・ポンテとのコンビで傑作連発。しかしウィーンの聴衆は冷淡になっていく。",
      "tags": [
        "breakthrough"
      ]
    },
    {
      "year": 1787,
      "age": 31,
      "title": "父レオポルト死去",
      "detail": "長年確執のあった父が亡くなる。直前の手紙に『死は人生の最後の目的地ではなく、本当の親友です』と書いた。同年『ドン・ジョヴァンニ』を書く。",
      "tags": [
        "loss",
        "parent_conflict"
      ]
    },
    {
      "year": 1791,
      "age": 35,
      "title": "『レクイエム』未完のまま死去",
      "detail": "匿名の依頼で書いた鎮魂曲。自らの死を予感した。死因は現在も諸説。貧民墓地に埋葬された。",
      "tags": [
        "loss",
        "illness",
        "poverty"
      ]
    },
    {
      "year": 1791,
      "age": 35,
      "title": "謎の依頼主からの『レクイエム』、未完のまま死去",
      "detail": "黒衣の使者が匿名で依頼した鎮魂曲。モーツァルト自身『これは私のレクイエムだ』と予感しながら書き続け、『ラクリモサ』の8小節目で絶筆。12月5日没。貧民墓地に埋葬され、どこに眠るかもわからない。",
      "tags": [
        "loss",
        "poverty"
      ]
    }
  ],
  "quotes": [
    {
      "text": "音楽は音符にあるのではなく、その間にある沈黙にある。",
      "source": "伝承"
    },
    {
      "text": "愛、愛、愛—これが音楽の精神である。",
      "source": "書簡"
    },
    {
      "text": "メロディは音楽の神髄である。",
      "source": "書簡"
    },
    {
      "text": "死は人生の真の最終目的である。そして死こそ人間の最良の友である。",
      "source": "父への手紙 1787"
    },
    {
      "text": "私は早く書く訳ではない。ただ、書く前に、もう全部頭の中で出来上がっているのだ。",
      "source": "モーツァルトに帰される言葉"
    },
    {
      "text": "私はまず書く前に、すべてを頭の中で聴く。ペンは残りの仕事をするだけだ。",
      "source": "書簡"
    },
    {
      "text": "愛こそが、天才の真の啓示である。",
      "source": "書簡"
    }
  ],
