{
  "id": "dutilleux",
  "name": "アンリ・デュティユー",
  "nameEn": "Henri Dutilleux",
  "birth": 1916,
  "death": 2013,
  "country": "フランス",
  "field": "作曲家",
  "summary": "20世紀フランスを代表する作曲家。若くして最高賞を取りながら、30代で過去の自分の作品をほぼ全て否定して破棄。遅筆で知られ、完璧主義と自己批判の果てに『本当の自分の音』を見つけた人。",
  "events": [
    {
      "year": 1916,
      "age": 0,
      "title": "北フランスのドゥエに生まれる",
      "detail": "祖父は指揮者、曾祖父は画家クールベと親交のある画家という芸術一家。戦争と芸術が交錯する家系に生まれ、『表現するとは何か』が幼い頃から問いとして存在していた。",
      "tags": [
        "approval"
      ]
    },
    {
      "year": 1916,
      "age": 0,
      "title": "フランス北部ドゥーエに誕生",
      "detail": "一族に画家（デルフトのフェルメールとの遠縁説あり）や音楽家が多い文化的家系。",
      "tags": []
    },
    {
      "year": 1933,
      "age": 17,
      "title": "パリ音楽院へ入学",
      "detail": "才能を認められ名門パリ音楽院へ。周囲の期待を一身に背負い、ラヴェルやドビュッシーの系譜を継ぐ者として育てられ始める。だがその期待こそが後の彼を苦しめることになる。",
      "tags": [
        "approval"
      ]
    },
    {
      "year": 1938,
      "age": 22,
      "title": "ローマ大賞を受賞",
      "detail": "フランス作曲家の最高登竜門を突破し、奨学金でローマ滞在が約束される。若き天才として前途が開けた矢先、歴史が割り込んでくる。",
      "tags": [
        "approval",
        "breakthrough"
      ]
    },
    {
      "year": 1940,
      "age": 24,
      "title": "第二次大戦で兵役、ドイツ軍の捕虜に",
      "detail": "これからという時期に徴兵され、フランスの敗北で捕虜となる。音楽から強制的に引き剥がされた時間。『これから書くはずだった曲』がすべて宙に浮いた。帰還後も、戦争がもたらした断絶は深く残り続ける。",
      "tags": [
        "blank_period",
        "setback",
        "loss"
      ]
    },
    {
      "year": 1940,
      "age": 24,
      "title": "第二次大戦で捕虜、脱走",
      "detail": "ドイツに捕虜として送られるがフランスへ脱出。占領下のパリで音楽を続ける。",
      "tags": [
        "isolation",
        "restart"
      ]
    },
    {
      "year": 1943,
      "age": 27,
      "title": "結婚、ピアニスト ジュヌヴィエーヴ・ジョワとの共同生活",
      "detail": "優れたピアニストの妻は、生涯を通じて彼の創作の最初の聴き手であり続けた。孤独な自己批判の作業を、彼女の存在だけが支えた。",
      "tags": [
        "turning_encounter"
      ]
    },
    {
      "year": 1948,
      "age": 32,
      "title": "過去の作品をほぼ全て否定、作品番号から抹消",
      "detail": "戦前から書き溜めた曲を『周囲の期待に合わせて書いた、自分の声ではない』と判断。公式作品リストから削除してしまう。30代に差しかかった頃、栄光も技術も一度捨てて裸になる決意。自己再構築の始まり。",
      "tags": [
        "self_reinvention",
        "pride_broken",
        "self_denial"
      ]
    },
    {
      "year": 1951,
      "age": 35,
      "title": "交響曲第1番 — ようやく『本当の自分の音』",
      "detail": "作品を捨ててから書き直した最初の大作。『過去のぬるま湯から脱け出す必要があった』と後年本人が語る。遅咲きの出発点。",
      "tags": [
        "restart",
        "breakthrough"
      ]
    },
    {
      "year": 1951,
      "age": 35,
      "title": "交響曲第1番、自作への厳しい態度",
      "detail": "若書きを次々破棄し、自作番号を振り直し続けた。完璧主義の化身。",
      "tags": [
        "breakthrough",
        "pride_broken"
      ]
    },
    {
      "year": 1954,
      "age": 38,
      "title": "ピアニストのジュヌヴィエーヴ・ジョワと結婚",
      "detail": "生涯の芸術的パートナー。彼女のために多くのピアノ曲を書いた。",
      "tags": [
        "turning_encounter"
      ]
    },
    {
      "year": 1959,
      "age": 43,
      "title": "交響曲第2番『二重』— 遅筆の代名詞になる",
      "detail": "1曲に何年もかける執拗な推敲。同時代の多作な作曲家たちと真逆の道を選ぶ。『書ける曲が少ない』のではなく『許せる曲が少ない』。完璧主義が彼自身を締め付け続けた。",
      "tags": [
        "self_denial",
        "breakthrough"
      ]
    },
    {
      "year": 1964,
      "age": 47,
      "title": "チェロ協奏曲『遙かなる遠い世界』",
      "detail": "ロストロポーヴィチの委嘱。ボードレールの『悪の華』に着想。現代チェロ曲の最高峰。",
      "tags": [
        "breakthrough"
      ]
    },
    {
      "year": 1967,
      "age": 51,
      "title": "パリ音楽院教授に就任",
      "detail": "自分が縛られてきた『音楽院のシステム』の中に、今度は教える側として立つ。学生には『自分の声を探せ、模倣するな』と説いたとされる。",
      "tags": [
        "self_reinvention"
      ]
    },
    {
      "year": 1970,
      "age": 54,
      "title": "パリ国立高等音楽院教授を辞退",
      "detail": "作曲に専念するため。『教えることは素晴らしいが、私には時間がない』",
      "tags": []
    },
    {
      "year": 1985,
      "age": 69,
      "title": "『時の影』初演",
      "detail": "アウシュヴィッツで死んだ少女アンネ・フランクに捧げる楽章を含む作品。戦争によって中断された自分の青春と重ね、半世紀を経てようやく『あの時の空白』に音楽で応えた。",
      "tags": [
        "loss",
        "self_reinvention"
      ]
    },
    {
      "year": 2008,
      "age": 92,
      "title": "妻ジュヌヴィエーヴを失う",
      "detail": "60年寄り添った妻。以後一人で暮らした。",
      "tags": [
        "loss",
        "heartbreak"
      ]
    },
    {
      "year": 2013,
      "age": 97,
      "title": "パリで没、最期まで完璧を求め続けた生涯",
      "detail": "生涯作品数は交響曲2曲、弦楽四重奏1曲など極端に少ない。だがどれもが磨き抜かれた一曲。『遅く書くこと』を恥じず、自分のペースを最後まで守り通した。",
      "tags": [
        "breakthrough"
      ]
    },
    {
      "year": 2013,
      "age": 97,
      "title": "パリで死去",
      "detail": "生涯で残した作品は少ない（約80曲）が全てが珠玉。現代フランス音楽の最後の巨匠。",
      "tags": [
        "loss"
      ]
    }
