  "quotes": [
    {
      "text": "霊感は怠け者を訪れない。",
      "source": "書簡"
    },
    {
      "text": "音楽とは、言葉では表せない感情を表現するために与えられた言語である。",
      "source": "メック夫人への手紙"
    },
    {
      "text": "霊感は、客人ではなく友人である。呼んでも来ず、呼ばなくても来る。",
      "source": "日記"
    },
    {
      "text": "もしあなたが運命と戦うなら、戦いそのものが、人生を価値あるものにするだろう。",
      "source": "書簡"
    },
    {
      "text": "孤独こそ、音楽の最大の贈り物である。",
      "source": "メック夫人への手紙"
    },
    {
      "text": "苦しみは、美しい音楽の最良の教師だ。",
      "source": "日記"
    },
    {
      "text": "私が死んでも、私の音楽が私を語ってくれる。",
      "source": "書簡"
    }
  ],
