  "quotes": [
    {
      "text": "私は若すぎる世界で生まれるには、あまりにも老人すぎた。",
      "source": "自伝的断章"
    },
    {
      "text": "人生で一番大事なのは、退屈しないことだ。",
      "source": "サティの日記"
    },
    {
      "text": "家具の音楽——人々が聴かずに聴き流すための音楽。",
      "source": "サティの新ジャンル提唱"
    },
    {
      "text": "私は若すぎる世界に、歳を取りすぎて生まれた。",
      "source": "サティの言葉"
    },
    {
      "text": "聴かないでください！ 聴かないで！",
      "source": "『家具の音楽』初演中に叫んだ言葉"
    },
    {
      "text": "いつもと同じに、でも違うように。",
      "source": "弟子への助言"
    }
