  "quotes": [
    {
      "text": "音楽は建築と科学の子供である。",
      "source": "サン=サーンスの言葉"
    },
    {
      "text": "趣味は不滅ではない。流行は滅びる。",
      "source": "書簡"
    },
    {
      "text": "音楽の規則を知り、それを超えよ。",
      "source": "弟子フォーレに"
    },
    {
      "text": "才能は義務である、それを怠るな。",
      "source": "書簡"
    },
    {
      "text": "私は常に、音楽と数学の両方を愛した。",
      "source": "晩年の手記"
    }
  ],
