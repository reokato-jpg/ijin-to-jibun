  "quotes": [
    {
      "text": "音楽は音と音の間のリズムと色彩の旋律で成り立つ。",
      "source": "手紙より"
    },
    {
      "text": "音楽は、音符と音符のあいだの、沈黙でできている。",
      "source": "ドビュッシーに帰される言葉"
    },
    {
      "text": "芸術は最も美しい嘘である。",
      "source": "ドビュッシーの言葉"
    },
    {
      "text": "音楽の規則はあなた自身である。",
      "source": "弟子への言葉"
    }
