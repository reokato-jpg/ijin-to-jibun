  "quotes": [
    {
      "text": "音楽は愛である。私の愛は音楽である。",
      "source": "『回想録』"
    },
    {
      "text": "時間だけが、真の批評家である。",
      "source": "書簡"
    },
    {
      "text": "音楽は感情の中で化学反応を起こす科学だ。",
      "source": "『回想録』"
    },
    {
      "text": "私は音楽を信じる。それだけが私を救う。",
      "source": "書簡"
    },
    {
      "text": "偉大さは、自分の時代に孤独であることだ。",
      "source": "書簡"
    }
