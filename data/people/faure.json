  "quotes": [
    {
      "text": "音楽は、不可能なものへの渇望である。",
      "source": "フォーレの手紙"
    },
    {
      "text": "静けさと微光——それが私の音楽の本質だ。",
      "source": "弟子への手紙"
    },
    {
      "text": "音楽は発明ではなく発見だ。",
      "source": "弟子への言葉"
    },
    {
      "text": "完成された美は、未完成を残す。",
      "source": "フォーレの手記"
    },
    {
      "text": "私のレクイエムは死の歌ではなく、死への愛撫だ。",
      "source": "自作解説"
    }
  ],
