  "quotes": [
    {
      "text": "技術を超えたところに、音楽がある。",
      "source": "リストの言葉"
    },
    {
      "text": "音楽は心の言語である。",
      "source": "リストの書簡"
    },
    {
      "text": "悲しみとは、私が最も深い歌を書ける素材である。",
      "source": "日記"
    },
    {
      "text": "天才は理解されない義務を持つ。",
      "source": "リストに帰される言葉"
    }
