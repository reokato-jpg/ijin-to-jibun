  "quotes": [
    {
      "text": "旅に病んで夢は枯野をかけ廻る",
      "source": "辞世の句"
    },
    {
      "text": "月日は百代の過客にして、行き交ふ年も又旅人なり。",
      "source": "『奥の細道』冒頭"
    },
    {
      "text": "古池や 蛙飛びこむ 水の音",
      "source": "1686年の名句"
    },
    {
      "text": "夏草や 兵どもが 夢の跡",
      "source": "『奥の細道』平泉"
    },
    {
      "text": "閑さや 岩にしみ入る 蝉の声",
      "source": "『奥の細道』立石寺"
    },
    {
      "text": "不易流行。",
      "source": "芭蕉の俳論"
    },
    {
      "text": "松のことは松に習え、竹のことは竹に習え。",
      "source": "『三冊子』"
