  "quotes": [
    {
      "text": "音楽は映像の感情そのものである。",
      "source": "久石譲の言葉"
    },
    {
      "text": "シンプルで、美しく、心に残ること。",
      "source": "作曲のモットー"
    },
    {
      "text": "映像が何を求めているかを、音で答える。",
      "source": "久石譲の言葉"
    },
    {
      "text": "メロディの力は、時代を超える。",
      "source": "書簡"
    },
    {
      "text": "子供の心で作る曲こそ、一番難しい。",
      "source": "作曲ノート"
    },
    {
      "text": "無駄を削ぎ落として残った旋律だけが、時を超える。",
      "source": "久石譲の言葉"
    }
  ],
