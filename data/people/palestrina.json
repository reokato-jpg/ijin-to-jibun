  "quotes": [
    {
      "text": "すべての声部は、神に捧げる祈りである。",
      "source": "パレストリーナの言葉"
    },
    {
      "text": "沈黙の中にこそ、神の声がある。",
      "source": "パレストリーナの言葉"
    },
    {
      "text": "多声は一つの魂に至る道だ。",
      "source": "書簡"
    },
    {
      "text": "音楽は、祈りが形を得たものだ。",
      "source": "パレストリーナの言葉"
    },
    {
      "text": "私の仕事は、神と聴衆のあいだの通訳である。",
      "source": "書簡"
    }
