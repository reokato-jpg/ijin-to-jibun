  "quotes": [
    {
      "text": "古代は失われたのではない。音楽の中に眠っている。",
      "source": "レスピーギの言葉"
    },
    {
      "text": "ローマの松が、私に永遠を教えた。",
      "source": "レスピーギの手記"
    },
    {
      "text": "古い楽譜にこそ、新しい音楽のヒントがある。",
      "source": "書簡"
    },
    {
      "text": "過去の音と新しい音、その間の橋を架けたい。",
      "source": "書簡"
    },
    {
      "text": "ローマの石が、私に音を教えてくれる。",
      "source": "レスピーギの手記"
    }
  ],
