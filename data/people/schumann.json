{
  "id": "schumann",
  "name": "ロベルト・シューマン",
  "nameEn": "Robert Schumann",
  "birth": 1810,
  "death": 1856,
  "country": "ドイツ",
  "field": "作曲家",
  "summary": "ピアニストの夢を手の故障で絶たれ、作曲家へ転身。愛する人の父に猛反対されながら結婚を勝ち取るも、若い頃から抱えていた精神の病に最後は飲み込まれていく。愛と狂気のあいだを揺れ続けた人。",
  "events": [
    {
      "year": 1810,
      "age": 0,
      "title": "ザクセンの書店主の家に生まれる",
      "detail": "父は文学好きで、家には詩集と楽譜が溢れていた。『音楽家になるか、詩人になるか』で揺れる気質は生涯続く。のちに彼は批評家としても文章を書き、言葉と音を行き来する稀有な存在となる。",
      "tags": [
        "approval"
      ]
    },
    {
      "year": 1826,
      "age": 16,
      "title": "父の死、姉エミーリエの自殺",
      "detail": "同じ年に相次いで家族を失う。父の死はうつの始まり、姉の自殺は『自分も同じ血筋だ』という恐怖の始まり。以後、彼は『自分も狂うのではないか』という不安を抱え続けた。",
      "tags": [
        "loss",
        "illness"
      ]
    },
    {
      "year": 1826,
      "age": 16,
      "title": "父と姉を相次いで失う",
      "detail": "父は突然死、姉エミーリエは精神を病み入水自殺。母はロベルトを法律家にしようとした。",
      "tags": [
        "loss"
      ]
    },
    {
      "year": 1828,
      "age": 18,
      "title": "母の意向でライプツィヒ大学の法学部へ",
      "detail": "母は『音楽家は食えない』と法律家を望んだ。本人は講義に出ず、毎日ピアノを弾いていた。『やりたくないこと』を表面上こなしながら、内側で本当の夢が膨らんでいく。",
      "tags": [
        "parent_conflict",
        "escape"
      ]
    },
    {
      "year": 1830,
      "age": 20,
      "title": "法学を捨て、音楽家を志す",
      "detail": "母に『お願いだから音楽をやらせてほしい』と懇願の手紙を書き、ヴィーク教授のもとに弟子入り。親が敷いたレールから初めて外れた決断。",
      "tags": [
        "restart",
        "parent_conflict"
      ]
    },
    {
      "year": 1830,
      "age": 20,
      "title": "ヴィーク門下で指を壊し、ピアニストの道を断つ",
      "detail": "指を鍛える器具で中指を傷め、演奏家としての道を失う。作曲家に賭けるしかなくなった。",
      "tags": [
        "pride_broken",
        "restart",
        "illness"
      ]
    },
    {
      "year": 1832,
      "age": 22,
      "title": "練習器具の無理使いで手指を故障、ピアニストの道が絶たれる",
      "detail": "指を独立させる器具を自作し、指を吊り上げて練習していた結果、右手の中指が機能不全に。最大のアイデンティティを失う。『私は自分を壊した』と日記に記す。作曲家へ転身するしかなくなった。",
      "tags": [
        "pride_broken",
        "setback",
        "self_denial"
      ]
    },
    {
      "year": 1833,
      "age": 23,
      "title": "抑うつの最初の深刻な発作、自殺願望",
      "detail": "高所恐怖と死への恐怖が同時に出現。『窓から飛び降りたい衝動』と戦う日々。若い頃から精神の病は既に芽吹いていた。",
      "tags": [
        "illness",
        "self_denial",
        "isolation"
      ]
    },
    {
      "year": 1834,
      "age": 23,
      "title": "『新音楽時報』創刊",
      "detail": "音楽批評誌を創刊、ショパン・ブラームスを『新しい道』と世に紹介した。『フロレスタン』『オイゼビウス』の筆名。",
      "tags": [
        "breakthrough"
      ]
    },
    {
      "year": 1835,
      "age": 25,
      "title": "師ヴィークの娘クララと恋に落ちる",
      "detail": "16歳年下、9歳から知っていた少女との恋。ピアニストとしての才能もある少女だった。ヴィーク家に下宿していた頃の記憶が、少しずつ愛情に変わっていた。",
      "tags": [
        "turning_encounter"
      ]
    },
    {
      "year": 1837,
      "age": 27,
      "title": "クララへの求婚、父ヴィークに激しく拒絶される",
      "detail": "『娘をお前のような精神不安定な男にやれない』と猛反対。手紙も取り上げられ、会うことすら禁じられた。4年にわたる裁判闘争が始まる。",
      "tags": [
        "parent_conflict",
        "heartbreak"
      ]
    },
    {
      "year": 1840,
      "age": 29,
      "title": "『歌の年』—師ヴィークを裁判で破りクララと結婚",
      "detail": "クララの父は猛反対し裁判に。勝訴後の歓喜の中で140曲以上の歌曲を作った。『詩人の恋』もこの年。",
      "tags": [
        "turning_encounter",
        "breakthrough"
      ]
    },
    {
      "year": 1844,
      "age": 34,
      "title": "ロシア演奏旅行後、深刻な神経衰弱",
      "detail": "妻クララの方が演奏家として有名になっていく現実。『クララの夫』と紹介される屈辱。嫉妬と劣等感が、元々あった病を悪化させていく。",
      "tags": [
        "jealousy",
        "illness",
        "self_denial"
      ]
    },
    {
      "year": 1853,
      "age": 43,
      "title": "若きブラームスと出会い、激賞する",
      "detail": "20歳のブラームスがシューマン家の扉を叩いた日。『新しい天才が現れた』と批評文に書く。自分の創造力が衰える中で、次世代に希望を託した瞬間。ブラームスは以後、シューマン家を支え続けることになる。",
      "tags": [
        "turning_encounter"
      ]
    },
    {
      "year": 1854,
      "age": 43,
      "title": "ライン川に投身、以後精神病院へ",
      "detail": "幻聴に苦しみライン川に飛び込むが漁師に救われる。自らの望みでエンデニッヒの療養院に入る。",
      "tags": [
        "illness",
        "pride_broken"
      ]
    },
    {
      "year": 1856,
      "age": 46,
      "title": "精神病院で死去、クララは2年半で会えたのは2度だけ",
      "detail": "医師は『面会は刺激になる』と会わせなかった。死の直前にようやく許可が下り、クララは夫に葡萄酒を飲ませた。それが最後だった。愛を勝ち取るために戦い、病に愛する人を奪われた生涯。",
      "tags": [
        "loss",
        "illness"
      ]
    }
  ],
  "relations": [
    {
      "name": "クララ・シューマン",
