  "quotes": [
    {
      "text": "私の耳は死んでも、私の音楽は生き続ける。",
      "source": "スメタナの言葉"
    },
    {
      "text": "ブルタバの流れは、チェコの魂である。",
      "source": "『我が祖国』序"
    },
    {
      "text": "チェコ人の血が、私の五線譜に流れている。",
      "source": "スメタナの書簡"
    },
    {
      "text": "聞こえない音楽こそ、最も純粋な音楽だ。",
      "source": "晩年の手記"
    },
    {
      "text": "祖国は母、母は音楽。",
      "source": "スメタナの言葉"
    }
  ],
