  "quotes": [
    {
      "text": "私の言葉が通じない国でも、音楽は通じた。",
      "source": "ロンドンからの手紙"
    },
    {
      "text": "年老いて弱くなったが、曲想は限りなく流れてくる。",
      "source": "晩年の手紙"
    },
    {
      "text": "神は喜びを好まれる。ゆえに私の音楽は喜ばしくあるべきだ。",
      "source": "ハイドンの言葉"
    }
